# Central experiment variables.
#
# Copy to `configs/experiment.env` for local runs if needed. Do not commit the
# copied file. In Colab, prefer Colab secrets or environment variables for
# secrets, and keep this file as documentation of required names.

# GitHub source repository.
REPO_URL=https://github.com/NosenkoArtem/diffusion_gemma_bench.git
CODE_BRANCH=main
RESULTS_BRANCH=bench-results

# Experiment selection.
PROFILE=q6_core_native
PHASE=backend-check
PROJECT_DIR=/content/diffusion_gemma_bench

# Optional runtime ports.
VLLM_HOST=127.0.0.1
VLLM_PORT=8000

# Notebook-only prompts for VS Code + Colab extension when Colab Secrets are not
# available. Values are flags, not secrets.
PROMPT_FOR_HF_TOKEN=1
PROMPT_FOR_GITHUB_TOKEN=0

# Secrets. Keep values empty here.
# Required before model/backend artifact checks:
HF_TOKEN=
# Alternative name accepted by Hugging Face tooling:
HUGGING_FACE_HUB_TOKEN=
# Required only for pushing result runs from Colab to private GitHub repos:
GITHUB_TOKEN=
